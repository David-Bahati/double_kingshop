{
  "name": "dks-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "index.cjs",
  "scripts": {
    "start": "node index.cjs",
    "dev": "nodemon --watch . --ext js,cjs,json --ignore node_modules index.cjs",
    "prod": "NODE_ENV=production node index.cjs",
    "lint": "eslint . --ext js,cjs",
    "test": "node --test",
    "db:backup": "node scripts/backup-db.cjs",
    "db:seed": "node scripts/seed-db.cjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "multer": "^1.4.5-lts.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "fedapay": "^1.2.5",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
