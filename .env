# ========================================
# 🏪 DOUBLE KING SHOP - Configuration Production
# ========================================

# 🎯 Mode d'exécution
NODE_ENV=production

# ========================================
# 🔗 API & BACKEND (ADRESSE RAILWAY)
# ========================================
# Cette URL est celle de votre backend actif sur Railway
VITE_API_URL=https://doublekingshop-production-5fdb.up.railway.app/api

# Temps d'attente max pour éviter le chargement infini (15 secondes)
VITE_API_TIMEOUT=15000
VITE_API_RETRY_COUNT=3

# ========================================
# 🥧 PI NETWORK CONFIGURATION
# ========================================
# Votre ID d'application Pi
VITE_PI_APP_ID=wl6mweqqcbdbrrawtolalqpusbu7s9emtuui7x3ps9q0ngvtxfdvcsvy8nlgvgh7

# Mode : 'sandbox' pour les tests, 'production' pour le lancement réel
VITE_PI_NETWORK=sandbox

# Taux GCV utilisé pour la boutique (1 Pi = 314,159 USD)
VITE_PI_GCV_RATE=314159

# ========================================
# 💳 FEDAPAY / MOBILE MONEY
# ========================================
# Mode : 'sandbox' pour tests, 'live' pour production
VITE_FEDAPAY_MODE=sandbox

# ========================================
# 🏪 APPLICATION CONFIGURATION
# ========================================
VITE_APP_NAME=Double King Shop
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Votre boutique informatique professionnelle à Bunia, Ituri.
VITE_APP_URL=https://doublekingshop-production-5fdb.up.railway.app

# ========================================
# 📞 CONTACT & SUPPORT (BUNIA)
# ========================================
VITE_CONTACT_EMAIL=bahatinyeke@gmail.com
VITE_CONTACT_PHONE=+243823038945
VITE_SHOP_ADDRESS=Avenue du Commerce, Bunia, Ituri, RDC

# ========================================
# 💱 DEVISES & TAUX (RDC)
# ========================================
VITE_DEFAULT_CURRENCY=USD
VITE_LOCAL_CURRENCY=CDF
VITE_CDF_RATE=2850

# Précision décimales
VITE_CURRENCY_DECIMALS_USD=2
VITE_CURRENCY_DECIMALS_CDF=0
VITE_CURRENCY_DECIMALS_PI=8

# ========================================
# 📱 PWA & MOBILE
# ========================================
VITE_ENABLE_PWA=true
VITE_DEPLOY_TARGET=railway
VITE_ENABLE_ANIMATIONS=true
