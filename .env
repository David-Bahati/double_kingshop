# ========================================
# 🏪 DOUBLE KING SHOP - Configuration
# ========================================

# 🎯 Mode d'exécution (development | production)
NODE_ENV=development

# ========================================
# 🥧 PI NETWORK CONFIGURATION
# ========================================
# ID de l'application Pi (obtenu sur https://develop.minepi.com)
VITE_PI_APP_ID=wl6mweqqcbdbrrawtolalqpusbu7s9emtuui7x3ps9q0ngvtxfdvcsvy8nlgvgh7

# Mode Pi : 'sandbox' pour les tests, 'production' pour le live
VITE_PI_NETWORK=sandbox

# Clé API Pi (SECRÈTE - à garder côté backend uniquement)
# ⚠️ NE PAS exposer cette variable dans le frontend (VITE_)
# PI_API_KEY=ta_cle_api_pi_secrete

# Taux GCV pour conversion Pi → USD (Global Consensus Value)
VITE_PI_GCV_RATE=314159

# ========================================
# 💳 FEDAPAY / MOBILE MONEY CONFIGURATION
# ========================================
# Clé secrète FedaPay (SECRÈTE - backend uniquement)
# FEDAPAY_SECRET_KEY=ta_cle_fedapay_secrete

# Mode FedaPay : 'sandbox' pour tests, 'live' pour production
VITE_FEDAPAY_MODE=sandbox

# URL publique FedaPay (pour webhooks)
VITE_FEDAPAY_WEBHOOK_URL=https://api.doublekingshop.com/api/mobile-money/webhook

# ========================================
# 🔗 API & BACKEND CONFIGURATION
# ========================================
# URL de l'API backend (utilisée par le frontend via proxy)
VITE_API_URL=https://api.doublekingshop.com

# URL de l'API en développement local (override si besoin)
# VITE_API_URL_DEV=http://localhost:3001

# Timeout des requêtes API (en millisecondes)
VITE_API_TIMEOUT=30000

# Nombre de tentatives de retry en cas d'échec API
VITE_API_RETRY_COUNT=3
# ========================================
# 🏪 APPLICATION CONFIGURATION
# ========================================
# Nom de l'application (affiché dans le titre, PWA, etc.)
VITE_APP_NAME=Double King Shop

# Version de l'application (auto-rempli par package.json si vide)
VITE_APP_VERSION=1.0.0

# Description pour SEO et PWA
VITE_APP_DESCRIPTION=Votre boutique informatique professionnelle à Bunia, Ituri. Paiements Pi Network, Mobile Money et Cash.

# URL de base de l'application (pour les liens canoniques, OG tags, etc.)
VITE_APP_URL=https://doublekingshop.com

# ========================================
# 📞 CONTACT & SUPPORT
# ========================================
# Email de contact (affiché dans le footer, reçus, etc.)
VITE_CONTACT_EMAIL=bahatinyeke@gmail.com

# Téléphone / WhatsApp (format international)
VITE_CONTACT_PHONE=+243823038945

# Adresse physique de la boutique
VITE_SHOP_ADDRESS=Avenue du Commerce, Bunia, Ituri, RDC

# Horaires d'ouverture (affiché sur le site)
VITE_SHOP_HOURS=Lun-Sam: 8h-18h • Dim: 9h-13h

# ========================================
# 💱 DEVISES & TAUX DE CHANGE
# ========================================
# Devise principale d'affichage (USD | CDF | PI)
VITE_DEFAULT_CURRENCY=USD

# Devise locale pour la RDC
VITE_LOCAL_CURRENCY=CDF

# Taux de change USD → CDF (à mettre à jour régulièrement)
VITE_CDF_RATE=2850

# Précision des décimales pour chaque devise
VITE_CURRENCY_DECIMALS_USD=2
VITE_CURRENCY_DECIMALS_CDF=0
VITE_CURRENCY_DECIMALS_PI=8

# ========================================
# 🔐 SÉCURITÉ & AUTHENTIFICATION
# ========================================# Longueur du PIN d'accès (4-6 chiffres recommandés)
VITE_PIN_LENGTH=4

# Durée de session en millisecondes (30 minutes par défaut)
VITE_SESSION_TIMEOUT=1800000

# Nombre maximal de tentatives de login avant lockout
VITE_MAX_LOGIN_ATTEMPTS=5

# Durée du lockout en millisecondes (15 minutes)
VITE_LOCKOUT_DURATION=900000

# Secret JWT pour signer les tokens (SECRÈTE - backend uniquement)
# JWT_SECRET=ton_secret_jwt_super_securise

# ========================================
# 📊 ANALYTICS & MONITORING (Optionnel)
# ========================================
# Google Analytics 4 Measurement ID (si utilisé)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN pour le tracking d'erreurs (si utilisé)
# VITE_SENTRY_DSN=https://xxx@oxxx.ingest.sentry.io/xxx

# Activer/désactiver les logs de debug dans le frontend
VITE_ENABLE_DEBUG_LOGS=false

# ========================================
# 🎨 UI & EXPÉRIENCE UTILISATEUR
# ========================================
# Thème par défaut : 'light' | 'dark' | 'system'
VITE_DEFAULT_THEME=system

# Activer les animations UI : true | false
VITE_ENABLE_ANIMATIONS=true

# Durée des notifications en millisecondes
VITE_NOTIFICATION_DURATION=5000

# Position des notifications : 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left'
VITE_NOTIFICATION_POSITION=top-right

# ========================================
# 📱 PWA & MOBILE CONFIGURATION
# ========================================
# Activer le Service Worker : true | false
VITE_ENABLE_PWA=true

# Stratégie de cache PWA : 'network-first' | 'cache-first' | 'stale-while-revalidate'
VITE_PWA_CACHE_STRATEGY=network-first
# Durée de cache des assets statiques en secondes (7 jours)
VITE_PWA_CACHE_MAX_AGE=604800

# ========================================
# 🚀 DÉPLOIEMENT & ENVIRONNEMENT
# ========================================
# Environnement de déploiement : 'vercel' | 'netlify' | 'railway' | 'custom'
VITE_DEPLOY_TARGET=vercel

# Activer la compression Gzip/Brotli dans le build : true | false
VITE_ENABLE_COMPRESSION=true

# Activer les source maps en production (déconseillé pour la sécurité)
VITE_ENABLE_SOURCE_MAPS=false