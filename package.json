{
  "name": "double-king-shop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Double King Shop - Système de gestion e-commerce complet pour Bunia, RDC. Paiements Pi Network, Mobile Money et Cash.",
  "author": {
    "name": "Double King Shop",
    "email": "bahatinyeke@gmail.com",
    "url": "https://doublekingshop.com"
  },
  "license": "MIT",
  "homepage": "https://doublekingshop.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ton-user/double-king-shop.git"
  },
  "bugs": {
    "url": "https://github.com/ton-user/double-king-shop/issues"
  },
  "keywords": [
    "e-commerce",
    "react",
    "vite",
    "pi-network",
    "mobile-money",
    "fedapay",
    "rdc",
    "bunia",
    "pos",
    "sqlite"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1",
  "scripts": {
    "start": "node server/index.cjs",
    "start:prod": "NODE_ENV=production node server/index.cjs",
    
    "dev": "concurrently \"pnpm run server:dev\" \"pnpm run client:dev\" -c \"blue,green\" -n \"API,WEB\"",
    "dev:full": "concurrently \"pnpm run server:dev\" \"pnpm run client:dev\" \"pnpm run monitor\" -c \"blue,green,yellow\" -n \"API,WEB,LOGS\"",
    
    "server": "cd server && node index.cjs",
    "server:dev": "cd server && nodemon --watch . --ext js,cjs,json --ignore node_modules index.cjs",
    "server:prod": "cd server && NODE_ENV=production node index.cjs",
    
    "client": "vite",
    "client:dev": "vite --host",    "client:build": "vite build",
    "client:preview": "vite preview --port 4173",
    
    "build": "pnpm run client:build",
    "build:prod": "NODE_ENV=production pnpm run client:build",
    "build:analyze": "pnpm run client:build --mode analyze",
    
    "preview": "pnpm run client:preview",
    "preview:prod": "pnpm run client:preview",
    
    "install:all": "pnpm install && cd server && pnpm install",
    "install:clean": "rm -rf node_modules server/node_modules pnpm-lock.yaml && pnpm install",
    
    "lint": "eslint src server --ext js,jsx,cjs --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src server --ext js,jsx,cjs --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,scss,json,md}\" \"server/**/*.{js,cjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,scss,json,md}\" \"server/**/*.{js,cjs,json,md}\"",
    
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "typecheck:watch": "tsc --noEmit --watch --project tsconfig.json",
    
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    
    "prepare": "husky install",
    "prepare:husky": "husky install && husky add .husky/pre-commit \"pnpm lint-staged\"",
    
    "pwa:generate": "npx @vite-pwa/assets-generator public/icons/icon-512x512.png --output public/icons",
    "pwa:check": "npx lighthouse http://localhost:4173 --view --only-categories=pwa",
    
    "deploy:vercel": "pnpm run build:prod && vercel --prod",
    "deploy:netlify": "pnpm run build:prod && netlify deploy --prod --dir=dist",
    "deploy:railway": "git push railway main",
    
    "monitor": "tail -f server/logs/*.log 2>/dev/null || echo '📁 Logs non disponibles'",
    "logs:server": "cd server && tail -f logs/app.log 2>/dev/null || echo '📁 Logs non disponibles'",
    
    "db:backup": "cd server && node scripts/backup-db.cjs",
    "db:seed": "cd server && node scripts/seed-db.cjs",
    "db:migrate": "cd server && node scripts/migrate-db.cjs",
    
    "clean": "rm -rf dist server/dist node_modules server/node_modules .vite *.log",
    "reset": "pnpm run clean && pnpm install",
    
    "health": "curl -f http://localhost:3001/api/health || echo '❌ Backend non disponible'",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test"
  },  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    
    "lucide-react": "^0.378.0",
    "recharts": "^2.12.7",
    "framer-motion": "^11.2.10",
    
    "zustand": "^4.5.2",
    
    "axios": "^1.7.2",
    
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "multer": "^1.4.5-lts.1",
    
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    
    "fedapay": "^0.6.0",
    
    "sweetalert2": "^11.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "@vite-pwa/assets-generator": "^0.2.4",
    "vite-plugin-pwa": "^0.20.0",
    
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    
    "vite": "^5.2.12",
    "terser": "^5.31.0",
    
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-config-prettier": "^9.1.0",
    
    "prettier": "^3.3.1",
    "prettier-plugin-tailwindcss": "^0.6.1",
    
    "husky": "^9.0.11",    "lint-staged": "^15.2.5",
    
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    
    "@playwright/test": "^1.44.1",
    
    "typescript": "^5.4.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.2"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/**/*.{js,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "iOS >= 12",
      "Android >= 6"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",      "last 1 safari version"
    ]
  }
}