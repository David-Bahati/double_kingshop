{
  "name": "double-king-shop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Double King Shop - Système de gestion e-commerce complet pour Bunia, RDC.",
  "author": {
    "name": "Double King Shop",
    "email": "bahatinyeke@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server/index.cjs",
    "start:prod": "NODE_ENV=production node server/index.cjs",
    "dev": "concurrently \"pnpm run server:dev\" \"pnpm run client:dev\" -c \"blue,green\" -n \"API,WEB\"",
    "server": "node server/index.cjs",
    "server:dev": "nodemon --watch server --ext js,cjs,json server/index.cjs",
    "client:build": "vite build",
    "build": "npx pnpm install && npx pnpm run client:build",
    "install:all": "npx pnpm install",
    "prepare": "echo 'Skip husky on Railway'",
    "clean": "rm -rf dist node_modules pnpm-lock.yaml",
    "db:migrate": "node server/scripts/migrate-db.cjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "lucide-react": "^0.378.0",
    "recharts": "^2.12.7",
    "framer-motion": "^11.2.10",
    "zustand": "^4.5.2",
    "axios": "^1.7.2",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "multer": "^1.4.5-lts.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "fedapay": "^1.2.5",
    "sweetalert2": "^11.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "@vite-pwa/assets-generator": "^0.2.4",
    "vite-plugin-pwa": "^0.20.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.12",
    "terser": "^5.31.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.1",
    "prettier-plugin-tailwindcss": "^0.6.1",
    "typescript": "^5.4.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.2"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  }
}
