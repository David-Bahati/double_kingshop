# ========================================
# 🏪 DOUBLE KING SHOP - Exemple de Configuration
# ========================================
# Copiez ce fichier en .env et remplissez les valeurs
# Les variables marquées [SECRET] ne doivent JAMAIS être commitées

# 🎯 Mode d'exécution
NODE_ENV=development

# 🥧 PI NETWORK
VITE_PI_APP_ID=your_pi_app_id_here
VITE_PI_NETWORK=sandbox
# PI_API_KEY=[SECRET: à mettre dans .env.local uniquement]
VITE_PI_GCV_RATE=314159

# 💳 FEDAPAY
# FEDAPAY_SECRET_KEY=[SECRET: backend uniquement]
VITE_FEDAPAY_MODE=sandbox
VITE_FEDAPAY_WEBHOOK_URL=https://api.doublekingshop.com/api/mobile-money/webhook

# 🔗 API
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000
VITE_API_RETRY_COUNT=3

# 🏪 APP
VITE_APP_NAME=Double King Shop
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Votre boutique informatique professionnelle à Bunia
VITE_APP_URL=http://localhost:3000

# 📞 CONTACT
VITE_CONTACT_EMAIL=contact@doublekingshop.com
VITE_CONTACT_PHONE=+243XXXXXXXXX
VITE_SHOP_ADDRESS=Votre adresse ici
VITE_SHOP_HOURS=Lun-Sam: 8h-18h

# 💱 DEVISES
VITE_DEFAULT_CURRENCY=USD
VITE_LOCAL_CURRENCY=CDF
VITE_CDF_RATE=2850
VITE_CURRENCY_DECIMALS_USD=2
VITE_CURRENCY_DECIMALS_CDF=0
VITE_CURRENCY_DECIMALS_PI=8

# 🔐 SÉCURITÉ
VITE_PIN_LENGTH=4
VITE_SESSION_TIMEOUT=1800000
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_LOCKOUT_DURATION=900000
# JWT_SECRET=[SECRET: backend uniquement]

# 📊 ANALYTICS (optionnel)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=your_sentry_dsn
VITE_ENABLE_DEBUG_LOGS=false

# 🎨 UI
VITE_DEFAULT_THEME=system
VITE_ENABLE_ANIMATIONS=true
VITE_NOTIFICATION_DURATION=5000
VITE_NOTIFICATION_POSITION=top-right

# 📱 PWA
VITE_ENABLE_PWA=true
VITE_PWA_CACHE_STRATEGY=network-first
VITE_PWA_CACHE_MAX_AGE=604800

# 🚀 DÉPLOIEMENT
VITE_DEPLOY_TARGET=vercel
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_SOURCE_MAPS=false